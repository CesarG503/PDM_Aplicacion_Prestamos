<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".InsertPrestamoActivity">

    <TextView
        android:id="@+id/tvTitlePrestamo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Registrar Préstamo"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <TextView
        android:id="@+id/tvArticuloLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Artículo:"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitlePrestamo"
        app:layout_constraintStart_toStartOf="parent" />

    <Spinner
        android:id="@+id/spArticulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/tvArticuloLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvPersonaLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Persona:"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/spArticulo"
        app:layout_constraintStart_toStartOf="parent" />

    <Spinner
        android:id="@+id/spPersona"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/tvPersonaLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilFechaPrestamo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/spPersona"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etFechaPrestamo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fecha de Préstamo (DD/MM/YYYY)" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilFechaDevolucion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tilFechaPrestamo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etFechaDevolucion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fecha Devolución Estimada" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnGuardarPrestamo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Registrar Préstamo"
        app:layout_constraintTop_toBottomOf="@id/tilFechaDevolucion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>